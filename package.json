{
  "name": "olivea",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20 <23"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "next dev --hostname olivea-localhost --port 3000",
    "dev:local": "cross-env HOST=olivea-localhost PORT=3000 next dev",
    "build": "next build",
    "start": "next start",
    "start:local": "cross-env HOST=olivea-localhost PORT=3000 next start",
    "lint": "eslint .",
    "analyze": "ANALYZE=true next build",
    "images:formats": "node scripts/convert-missing-formats.mjs",
    "press:web": "node scripts/press-web.mjs"
  },
  "browserslist": {
    "production": [
      "last 3 chrome versions",
      "last 3 firefox versions",
      "last 3 edge versions",
      "last 3 safari versions",
      "last 3 ios_saf versions",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "focus-trap-react": "^11.0.3",
    "framer-motion": "^12.23.22",
    "gray-matter": "^4.0.3",
    "gsap": "^3.13.0",
    "js-cookie": "^3.0.5",
    "lenis": "^1.3.3",
    "lucide-react": "^0.488.0",
    "negotiator": "^1.0.0",
    "next": "16.2.4",
    "next-mdx-remote": "^6.0.0",
    "punycode.js": "^2.3.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "reading-time": "^1.5.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^4.5.1",
    "tailwind-merge": "^3.2.0",
    "tw-animate-css": "^1.2.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.4",
    "@next/mdx": "16.2.4",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.5",
    "@tailwindcss/typography": "^0.5.16",
    "@types/gsap": "^1.20.2",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^24.7.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^9.37.0",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "fast-glob": "^3.3.3",
    "postcss": "^8.5.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-img-size": "^1.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-lint": "^10.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-markdown-style-guide": "^6.0.1",
    "remark-unwrap-images": "^4.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.5",
    "tailwindcss-animate": "^1.0.7",
    "ts-prune": "^0.10.3",
    "typescript": "^5",
    "webpack-bundle-analyzer": "^4.10.2"
  }
}
